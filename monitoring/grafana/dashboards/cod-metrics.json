{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "title": "ROAS Global",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "cod_global_roas", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Profit Global",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "cod_global_profit", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Taux de confirmation global",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "cod_global_confirmation_rate", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Commandes ingerees par statut",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (status) (cod_orders_ingested_total)", "refId": "A", "legendFormat": "{{status}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cod", "ecommerce", "media-buyers"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "COD & Media Buyers Monitoring",
  "uid": "cod-metrics",
  "version": 1
}
